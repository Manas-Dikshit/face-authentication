   "source": [
    "import os\n",
    "\n",
    "folder = \"Ml\"\n",
    "\n",
    "images = [\n",
    "    f for f in os.listdir(folder)\n",
    "    if f.lower().endswith((\".jpg\", \".jpeg\", \".png\", \".webp\", \".heic\"))\n",
    "]\n",
    "\n",
    "print(\"Total images:\", len(images))"
   ]
